{
  "name": "mkt",
  "version": "1.0.0",
  "description": "Makeit Protocol",
  "main": "index.js",
  "scripts": {
    "anvil": "node scripts/anvil.js",
    "build:solidity": "node scripts/forge.js build --root solidity -vvv",
    "build:solidity:local": "node scripts/forge.js build --root local_deploy_rust -q",
    "test:solidity": "node scripts/forge.js test --root solidity",
    "test:solidity:local": "node scripts/forge.js test --root local_deploy_rust",
    "test:solidity:invariant": "node scripts/forge.js test --root solidity --match-path test/Makeit.Invariant.t.sol",
    "deploy:local": "node scripts/deploy-local.js",
    "db:up": "node scripts/db-up.js",
    "db:up:fresh": "node scripts/db-up.js --fresh",
    "dev": "node scripts/dev.js",
    "dev:fresh": "node scripts/dev.js --fresh",
    "dev:rust": "node scripts/dev-rust.js",
    "dev:rust:fresh": "node scripts/dev-rust.js --fresh",
    "dev:contracts": "node scripts/dev.js --contracts-only",
    "dev:contracts:fresh": "node scripts/dev.js --contracts-only --fresh",
    "dev:apps": "node scripts/dev.js --apps-only",
    "deploy:all": "node scripts/deploy-all.js",
    "deploy:all:fresh": "node scripts/deploy-all.js --fresh",
    "deploy:all:with-db": "node scripts/deploy-all.js --with-db",
    "deploy:all:reset-db": "node scripts/deploy-all.js --reset-db",
    "up": "npm run dev:rust:fresh",
    "backend:install": "cd backend && cargo build",
    "backend:dev": "npm run dev:rust",
    "frontend:install": "npm --prefix frontend install",
    "frontend:dev": "node scripts/frontend-dev.js",
    "frontend:build": "npm --prefix frontend run build"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@uniswap/v3-core": "^1.0.0",
    "@uniswap/v3-periphery": "^1.3.0",
    "base64-sol": "^1.0.1",
    "ethers": "^6.16.0",
    "pg": "^8.11.3"
  }
}
