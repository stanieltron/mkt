# Frontend environment template
# Copy to .env and fill in values for local development
# For local Anvil stack: run "npm run local" — it auto-generates src/generated/network.generated.js
# which the app uses instead of these vars in local mode.
# These vars are mainly for manual overrides or non-local deployments.

VITE_BACKEND_URL=http://127.0.0.1:8787
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337
VITE_LOCAL_MODE=true

VITE_MAKEIT_ADDRESS=
VITE_ORACLE_ADDRESS=
VITE_SWAP_ADAPTER_ADDRESS=
VITE_USDC_ADDRESS=
VITE_USDT_ADDRESS=
VITE_WETH_ADDRESS=
VITE_UNISWAP_POOL_ADDRESS=

VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=
