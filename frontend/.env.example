# Frontend runtime env (used by scripts/start-gateway.cjs)
PORT=3000
BACKEND_URL=https://your-backend-service.up.railway.app
FRONTEND_RPC_URL=https://your-local-node-service.up.railway.app

# Optional fallback if FRONTEND_RPC_URL is unset
RPC_URL=

# Overlay controls (runner + faucet UI)
ENABLE_LOCAL_OVERLAYS=true
LOCAL_FAUCET_API_BASE=

# Optional mode flags exposed to UI via /api/config from backend
LOCAL_MODE=true
PUBLIC_MODE=false

# --- Optional Vite-only local overrides (dev only) ---
VITE_BACKEND_URL=http://127.0.0.1:8787
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337
VITE_LOCAL_MODE=true