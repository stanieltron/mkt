# --- GLOBAL CONFIGURATION (Used by both backends and frontend) ---

# Mode: 'true' for Public/Production (hides Faucet/SwapRunner), 'false' for Local/Dev
PUBLIC_MODE=false

# Blockchain Configuration
RPC_URL=http://localhost:8545
CHAIN_ID=31337

# Contract Addresses (V4)
MAKEIT_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
SWAP_ADAPTER_ADDRESS=0x0000000000000000000000000000000000000000
UNISWAP_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# Other Tokens (Vite Frontend only)
VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
VITE_WETH_ADDRESS=0x0000000000000000000000000000000000000000

# Backend Connection (Frontend only)
VITE_BACKEND_URL=http://localhost:8787

# --- BACKEND SPECIFIC (Rust & Node.js) ---

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/makeit

# Private Keys (DANGER: DO NOT COMMIT REAL KEYS)
# Runner for Price Oracle / SwapRunner (Dev only)
RUNNER_PRIVATE_KEY=
# Execution bot for liquidations
BOT_PRIVATE_KEY=
# Faucet wallet (Dev only, hidden if PUBLIC_MODE=true)
FAUCET_PRIVATE_KEY=

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- FRONTEND SPECIFIC (Prefix with VITE_) ---
# The frontend automatically picks up many of the above keys if they are prefixed with VITE_
# For standalone deployment, ensure the keys below are set in the .env of the frontend package:

VITE_PUBLIC_MODE=false
VITE_RPC_URL=...
VITE_CHAIN_ID=...
VITE_MAKEIT_ADDRESS=...
VITE_ORACLE_ADDRESS=...
VITE_BACKEND_URL=...
